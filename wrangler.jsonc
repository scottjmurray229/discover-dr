{
	"main": "dist/_worker.js/index.js",
	"name": "discover-dr",
  "compatibility_date": "2026-02-04",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"observability": {
    "enabled": true
  },
"d1_databases": [
    {
      "binding": "DB",
      "database_name": "trip-planner-cache-dr",
      "database_id": "4e5cd568-f751-4427-9e49-9197150f8a2b"
    }
  ]
}
