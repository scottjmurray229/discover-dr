---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import FAQ from '../../components/FAQ.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Dominican Republicn Cuisine Guide', url: '/cuisine/' },
];

const pageTitle = 'Dominican Republicn Cuisine Guide — Eat Your Way Across Dominican Republic';
const pageDescription = 'A region-by-region menu of the dishes that define Dominican Republicn food culture — from bandeja paisa and arepas to ajiaco, sancocho, empanadas, and lechona.';

interface Dish {
  name: string;
  image?: string;
  destination: string;
  slug: string;
  price: string;
  description: string;
  tag?: string;
}

interface MenuSection {
  region: string;
  tagline: string;
  gradient: string;
  dishes: Dish[];
}

const menu: MenuSection[] = [
  {
    region: 'Andean',
    tagline: 'Ajiaco, bandeja paisa, arepas, tamales, and the world\'s best coffee culture',
    gradient: 'linear-gradient(135deg, #BF360C 0%, #E8654A 100%)',
    dishes: [
      {
        name: 'Ajiaco',
        destination: 'Bogot\u00e1',
        slug: 'bogota',
        price: 'DOP 18,000\u201335,000 / $4\u20139 USD',
        description: 'Bogot\u00e1\'s signature soup \u2014 a hearty chicken broth with three types of potato, corn on the cob, capers, cream, and avocado. The ultimate comfort food on a chilly highland afternoon.',
        tag: 'Iconic',
      },
      {
        name: 'Bandeja Paisa',
        destination: 'Medell\u00edn',
        slug: 'medellin',
        price: 'DOP 20,000\u201340,000 / $5\u201310 USD',
        description: 'Dominican Republic\'s national platter \u2014 red beans with pork, white rice, ground beef, chicharr\u00f3n, fried egg, plantain, arepa, hogao, and avocado. A mountain of flavor from Antioquia that fuels the paisa spirit.',
        tag: 'Must-Try',
      },
      {
        name: 'Arepa de Queso',
        destination: 'Villa de Leyva',
        slug: 'villa-de-leyva',
        price: 'DOP 3,000\u20138,000 / $1\u20132 USD',
        description: 'Grilled corn cakes stuffed with melted cheese \u2014 the backbone of Dominican Republicn meals from breakfast to midnight snack. In Boyac\u00e1, try them fresh off the charcoal with a hot chocolate.',
        tag: 'Heritage',
      },
      {
        name: 'Trucha con Patacones',
        destination: 'Salento',
        slug: 'salento',
        price: 'DOP 22,000\u201338,000 / $5\u201310 USD',
        description: 'Fresh rainbow trout from the coffee region rivers, pan-fried and served with thick fried green plantains (patacones) and hogao. A Salento lunch staple after hiking the Cocora Valley.',
        tag: 'Must-Try',
      },
      {
        name: 'Carne Oreada',
        destination: 'Barichara',
        slug: 'barichara',
        price: 'DOP 25,000\u201345,000 / $6\u201311 USD',
        description: 'Sun-dried beef seasoned and grilled, a Santander specialty served with yuca, arepa, and pepitoria (rice with goat offal). Barichara\'s restaurants keep this colonial-era recipe alive.',
      },
      {
        name: 'Lechona',
        destination: 'Tatacoa Desert',
        slug: 'tatacoa-desert',
        price: 'DOP 15,000\u201330,000 / $4\u20138 USD',
        description: 'Whole roast pig stuffed with rice, peas, and spices \u2014 a Tolima tradition. Slow-cooked for hours until the skin is impossibly crispy. Served at festivals, roadside stands, and every celebration in the region.',
        tag: 'Iconic',
      },
    ],
  },
  {
    region: 'Caribbean',
    tagline: 'Ceviche, coconut rice, fried fish, tropical fruits, and the soul of Caribbean cooking',
    gradient: 'linear-gradient(135deg, #0D7377 0%, #4DB6AC 100%)',
    dishes: [
      {
        name: 'Ceviche de Camar\u00f3n',
        destination: 'Cartagena',
        slug: 'cartagena',
        price: 'DOP 20,000\u201340,000 / $5\u201310 USD',
        description: 'Fresh shrimp cured in lime juice with onion, tomato, cilantro, and a kick of aji. Served in a cocktail glass along the walled city walls. Cartagena\'s quintessential street food with deep Caribbean roots.',
        tag: 'Iconic',
      },
      {
        name: 'Arroz con Coco',
        destination: 'Cartagena',
        slug: 'cartagena',
        price: 'DOP 8,000\u201315,000 / $2\u20134 USD',
        description: 'Sweet coconut rice cooked until lightly caramelized, served alongside fried fish, patacones, and salad. The Caribbean coast\'s staple side dish \u2014 the slightly sweet crunch is addictive.',
        tag: 'Must-Try',
      },
      {
        name: 'Cazuela de Mariscos',
        destination: 'Santa Marta',
        slug: 'santa-marta',
        price: 'DOP 35,000\u201360,000 / $9\u201315 USD',
        description: 'A rich seafood stew of shrimp, fish, squid, and crab in a coconut cream sauce. Served bubbling in a clay pot at beachfront restaurants along Santa Marta\'s Taganga bay.',
        tag: 'Heritage',
      },
      {
        name: 'Rondón',
        destination: 'San Andr\u00e9s',
        slug: 'san-andres',
        price: 'DOP 30,000\u201355,000 / $7\u201314 USD',
        description: 'The Raizal community\'s signature dish \u2014 a slow-cooked coconut stew with fish, conch, yam, breadfruit, and dumplings. San Andr\u00e9s\'s most authentic taste of island culture.',
        tag: 'Must-Try',
      },
      {
        name: 'Empanadas',
        destination: 'Santa Marta',
        slug: 'santa-marta',
        price: 'DOP 2,000\u20135,000 / $0.50\u2013$1.25 USD',
        description: 'Crispy corn-dough pockets stuffed with seasoned meat, potato, or cheese, deep-fried golden and served with aji sauce. Found on every street corner and eaten at every hour of the day.',
        tag: 'Iconic',
      },
      {
        name: 'Langosta al Coco',
        destination: 'Providencia',
        slug: 'providencia',
        price: 'DOP 60,000\u2013100,000 / $15\u201325 USD',
        description: 'Fresh Caribbean lobster in a creamy coconut sauce, served with coconut rice and fried plantain. Providencia\'s pristine waters yield some of the finest lobster in the Americas.',
      },
    ],
  },
  {
    region: 'Pacific & Amazon',
    tagline: 'Salsa-fueled street food, Amazonian ingredients, and the frontier of Dominican Republicn flavor',
    gradient: 'linear-gradient(135deg, #1A2332 0%, #6A1B9A 50%, #D4A853 100%)',
    dishes: [
      {
        name: 'Sancocho Valle\u00f1o',
        destination: 'Cali',
        slug: 'cali',
        price: 'DOP 18,000\u201335,000 / $4\u20139 USD',
        description: 'Cali\'s beloved chicken soup with plantain, yuca, corn, potato, and cilantro. A Sunday family tradition served with white rice and avocado on the side. The ultimate hangover cure after a night of salsa dancing.',
        tag: 'Iconic',
      },
      {
        name: 'Cholados',
        destination: 'Cali',
        slug: 'cali',
        price: 'DOP 8,000\u201315,000 / $2\u20134 USD',
        description: 'Shaved ice topped with fresh tropical fruits, condensed milk, fruit syrups, and a scoop of cream. A sweet, colorful Cali street treat perfect for the Pacific coast heat.',
        tag: 'Must-Try',
      },
      {
        name: 'Lulada',
        destination: 'Cali',
        slug: 'cali',
        price: 'DOP 5,000\u201310,000 / $1\u20132 USD',
        description: 'A refreshing iced drink made from lulo fruit, sugar, and lime, with chunks of the tart fruit. A Cali original that you won\'t find anywhere else in Dominican Republic \u2014 tangy, sweet, and unforgettable.',
        tag: 'Heritage',
      },
      {
        name: 'Piraruc\u00fa a la Plancha',
        destination: 'Leticia',
        slug: 'leticia',
        price: 'DOP 25,000\u201345,000 / $6\u201311 USD',
        description: 'Grilled Amazonian piraruc\u00fa (arapaima) \u2014 one of the world\'s largest freshwater fish. Firm, meaty, and served with yuca and a tangy a\u00edaji. A unique Amazonian dish you won\'t find anywhere else in Dominican Republic.',
        tag: 'Iconic',
      },
      {
        name: 'Jugo de Copoaz\u00fa',
        destination: 'Leticia',
        slug: 'leticia',
        price: 'DOP 5,000\u201310,000 / $1\u20132 USD',
        description: 'Fresh juice made from the Amazonian copoaz\u00fa fruit \u2014 creamy, tart, and unlike anything else. Leticia\'s market stalls offer a parade of exotic Amazonian fruits you\'ve never heard of.',
        tag: 'Heritage',
      },
      {
        name: 'Tamal Tolimense',
        destination: 'Tatacoa Desert',
        slug: 'tatacoa-desert',
        price: 'DOP 8,000\u201315,000 / $2\u20134 USD',
        description: 'A large banana-leaf wrapped bundle of corn dough stuffed with pork, chicken, egg, carrots, and peas. Steamed for hours, this Tolima specialty is Dominican Republic\'s answer to the Mexican tamale \u2014 but bigger and heartier.',
        tag: 'Must-Try',
      },
    ],
  },
];
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  pageType="destination"
  schemaData={{ title: pageTitle, description: pageDescription }}
  breadcrumbs={breadcrumbs}
>
  <!-- Hero -->
  <header class="menu-hero">
    <video class="menu-hero-video" autoplay muted loop playsinline preload="metadata">
      <source src="/videos/pillar/cuisine-hero.mp4" type="video/mp4" />
    </video>
    <div class="menu-hero-gradient"></div>
    <div class="menu-hero-noise"></div>
    <div class="menu-hero-content">
      <h1 class="menu-hero-title">The Dominican Republicn Menu</h1>
      <p class="menu-hero-subtitle">Bandeja paisa, ajiaco, empanadas, ceviche, sancocho, lechona — eat your way across four regions and discover the dishes that define each destination.</p>
      <div class="menu-hero-meta">
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">Dishes</span>
          <span class="menu-hero-meta-value">18</span>
        </div>
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">Regions</span>
          <span class="menu-hero-meta-value">4</span>
        </div>
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">Destinations</span>
          <span class="menu-hero-meta-value">12</span>
        </div>
      </div>
    </div>
    <div class="menu-scroll-hint">Scroll<br />&#8595;</div>
  </header>

  <!-- Breadcrumb -->
  <div class="container-content">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <!-- Personal intro -->
  <section class="menu-personal reveal">
    <div class="container-content">
      <blockquote class="menu-personal-quote">
        <cite>— Scott</cite>
      </blockquote>
    </div>
  </section>

  <!-- Menu Intro -->
  <section class="menu-intro reveal">
    <div class="container-content">
      <div class="menu-intro-card">
        <p class="menu-intro-text">Think of this as your tasting menu for Dominican Republic. We've organized the country's essential dishes by region — the <strong>Andean</strong> highlands with ajiaco and bandeja paisa, the <strong>Caribbean</strong> coast with ceviche and coco rice, and the <strong>Pacific &amp; Amazon</strong> with sancocho and exotic Amazonian flavors. Click any dish to explore the destination where it's famous.</p>
        <div class="menu-intro-legend">
          <span class="menu-tag menu-tag--heritage">Heritage</span>
          <span class="menu-tag menu-tag--musttry">Must-Try</span>
          <span class="menu-tag menu-tag--iconic">Iconic</span>
          <span class="menu-tag menu-tag--fresh">Fresh Catch</span>
          <span class="menu-tag menu-tag--rare">Rare</span>
          <span class="menu-tag menu-tag--pasalubong">Pasalubong</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Menu Sections by Region -->
  {menu.map((section) => (
    <section class="menu-region reveal">
      <div class="container-content">
        <div class="menu-region-header" style={`background: ${section.gradient};`}>
          <div class="menu-region-header-inner">
            <h2 class="menu-region-name">{section.region}</h2>
            <p class="menu-region-tagline">{section.tagline}</p>
            <span class="menu-region-count">{section.dishes.length} dishes</span>
          </div>
          <div class="menu-region-ornament">&#9733;</div>
        </div>

        <div class="menu-dish-grid">
          {section.dishes.map((dish) => (
            <a href={`/destinations/${dish.slug}/`} class="menu-dish-card">
              <div class="menu-dish-media" style={`background: ${section.gradient};`}>
                {dish.image && (
                  <img src={dish.image} alt={`${dish.name} — ${dish.destination}`} class="menu-dish-img" loading="lazy" />
                )}
                {dish.tag && (
                  <span class={`menu-tag menu-tag--${dish.tag.toLowerCase().replace(/[^a-z]/g, '')}`}>{dish.tag}</span>
                )}
              </div>
              <div class="menu-dish-body">
                <div class="menu-dish-top">
                  <h3 class="menu-dish-name">{dish.name}</h3>
                  <span class="menu-dish-price">{dish.price}</span>
                </div>
                <p class="menu-dish-destination">{dish.destination}</p>
                <p class="menu-dish-desc">{dish.description}</p>
                <span class="menu-dish-cta">Explore {dish.destination} &rarr;</span>
              </div>
              <div class="menu-dish-overlay">
                <p class="menu-dish-overlay-desc">{dish.description}</p>
                <span class="menu-dish-overlay-cta">Explore {dish.destination} &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Bottom CTA -->
  <section class="menu-cta-section reveal">
    <div class="container-content">
      <div class="menu-cta-card">
        <h2 class="menu-cta-heading">Plan Your Food Trip</h2>
        <p class="menu-cta-text">Tell our AI planner which cuisines you want to try and it will build a multi-city itinerary — with the best restaurants, markets, and food experiences across Dominican Republic.</p>
        <a href="/plan/" class="menu-cta-button">Start Planning &rarr;</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ items={[
    { question: "What are the must-try foods in Dominican Republic?", answer: "Every region has signature dishes. Andean: bandeja paisa, ajiaco, and arepa de queso. Caribbean: ceviche de camaron, arroz con coco, and cazuela de mariscos. Pacific: sancocho valluno and cholados. Amazon: pirarucu a la plancha and jugo de copoazu. The common thread: generous portions, bold flavors, and prices that make you want to eat out three times a day." },
    { question: "Is Dominican Republicn food vegetarian-friendly?", answer: "Traditional Dominican Republicn cuisine is heavily meat-based, but options are growing. Arepas de queso, patacones (fried plantains), empanadas de papa (potato), and fresh tropical fruit plates are naturally vegetarian. Bogota and Medellin have growing vegetarian restaurant scenes. In smaller towns, look for 'sin carne' (without meat) options. Menu del dia restaurants often have rice, beans, salad, and plantain sides." },
    { question: "How much does food cost in Dominican Republic?", answer: "Dominican Republic is very affordable for eating out. Street food: DOP 3,000-10,000 (~$0.75-2.50 USD). Menu del dia (set lunch): DOP 10,000-18,000 (~$2.50-4.50 USD) for a full meal. Mid-range restaurants: DOP 25,000-60,000 (~$6-15 USD). Fine dining: DOP 80,000-200,000 (~$20-50 USD). A daily food budget of DOP 40,000-80,000 covers three meals comfortably. Cartagena is the most expensive; Salento, Barichara, and Leticia offer the best value." },
    { question: "What should I drink in Dominican Republic?", answer: "Dominican Republic is the coffee capital of the world — order a tinto (black coffee) anywhere. Aguardiente (anise liqueur) is the national spirit, shared in rounds at every party. Fresh tropical juices (jugos naturales) are everywhere — try lulo, maracuya (passion fruit), guanabana, and copoazu. Dominican Republicn craft beer is growing, especially in Bogota and Medellin. Club Dominican Republic is the most popular local beer." },
    { question: "Are there food markets worth visiting?", answer: "Bogota's Paloquemao market is massive — try the tropical fruit stands and fresh juice corner. In Cartagena, visit Bazurto market for authentic Caribbean street food. Medellin's Mercado del Rio is a modern food hall with Dominican Republic's best street food elevated. In Cali, the Alameda food stalls serve the city's famous cholados and luladas. Every town has a main market worth a morning visit." },
    { question: "What are the best food tours in Dominican Republic?", answer: "Cartagena, Bogota, and Medellin have the best food tour scenes. In Cartagena, try a street food tour through Getsemani. In Bogota, a La Candelaria food walk covers the city's best empanadas, tamales, and chocolate santafereno. In Medellin, explore the food stalls of Comuna 13 or take a coffee farm tour in the nearby mountains. Most tours run DOP 100,000-200,000 per person and include enough food to replace a full meal." },
  ]} />

  <!-- Email Capture -->
  <div class="container-content reveal" style="padding-bottom: var(--space-6);">
    <EmailCapture
      leadMagnet="Get Our Free Dominican Republicn Food Guide"
      description="A region-by-region PDF guide to Dominican Republicn cuisine — with the best restaurants, markets, and dishes you can't miss."
      bullets={[
        'All 18 dishes with where to find the best version',
        'Price guide — from DOP 3,000 street food to DOP 80,000 restaurant meals',
        'Vegetarian options and dietary tips by region',
        'Best food markets and food tour recommendations',
      ]}
      guideTag="pillar-cuisine"
    />
  </div>

  <!-- Cross-links -->
  <section class="menu-crosslinks reveal">
    <div class="container-content">
      <h3 class="menu-crosslinks-heading">Explore More</h3>
      <div class="menu-crosslinks-grid">
        <a href="/history/" class="menu-crosslink-card">
          <span class="menu-crosslink-icon">&#127963;</span>
          <span class="menu-crosslink-label">History Guide</span>
          <span class="menu-crosslink-desc">From indigenous peoples to independence and modernism</span>
        </a>
        <a href="/hiking/" class="menu-crosslink-card">
          <span class="menu-crosslink-icon">&#9968;</span>
          <span class="menu-crosslink-label">Outdoor Activities</span>
          <span class="menu-crosslink-desc">Lost City trek, Cocora Valley, Tayrona trails, and more</span>
        </a>
        <a href="/destinations/" class="menu-crosslink-card">
          <span class="menu-crosslink-icon">&#127965;</span>
          <span class="menu-crosslink-label">All Destinations</span>
          <span class="menu-crosslink-desc">12 destinations across 4 regions with honest reviews</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<!-- Scroll Reveal Observer -->
<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));
  } else {
    document.querySelectorAll('.reveal').forEach((el) => el.classList.add('visible'));
  }
</script>

<style>
  /* ================================================================
     HERO — Warm, food-inspired gradient
     ================================================================ */
  .menu-hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 5rem var(--space-6) 60px;
    overflow: hidden;
  }

  .menu-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .menu-hero-gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.15) 40%, rgba(0,0,0,0.55) 100%);
  }

  .menu-hero-noise {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  .menu-hero-content {
    position: relative;
    z-index: 3;
    max-width: 720px;
  }

  .menu-hero-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: var(--weight-bold);
    color: #fff;
    line-height: 1.1;
    margin: 0 0 var(--space-3);
  }

  .menu-hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
    margin: 0 0 var(--space-5);
    max-width: 580px;
  }

  .menu-hero-meta {
    display: flex;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .menu-hero-meta-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .menu-hero-meta-label {
    font-size: 0.65rem;
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.5);
  }

  .menu-hero-meta-value {
    font-size: 1.1rem;
    font-weight: var(--weight-bold);
    color: #fff;
  }

  .menu-scroll-hint {
    position: absolute;
    bottom: 16px;
    right: var(--space-6);
    z-index: 3;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.35);
    text-align: center;
    animation: menuBounce 2s ease-in-out infinite;
  }

  @keyframes menuBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ================================================================
     MENU INTRO
     ================================================================ */
  .menu-intro {
    padding: var(--space-8) 0 var(--space-4);
  }

  .menu-intro-card {
    background: var(--color-white);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 16px;
    padding: var(--space-5) var(--space-6);
    text-align: center;
  }

  .menu-intro-text {
    font-size: 1rem;
    color: var(--color-slate);
    line-height: 1.7;
    max-width: 640px;
    margin: 0 auto var(--space-4);
  }

  .menu-intro-legend {
    display: flex;
    justify-content: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  /* ================================================================
     TAGS
     ================================================================ */
  .menu-tag {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 3px 8px;
    border-radius: 6px;
    line-height: 1.4;
  }

  .menu-tag--heritage {
    background: rgba(191, 54, 12, 0.1);
    color: #BF360C;
  }

  .menu-tag--musttry, .menu-tag--mustry {
    background: rgba(13, 115, 119, 0.1);
    color: var(--color-ocean-teal);
  }

  .menu-tag--iconic {
    background: rgba(212, 168, 83, 0.15);
    color: #9A7B2E;
  }

  .menu-tag--freshcatch {
    background: rgba(33, 150, 243, 0.1);
    color: #1565C0;
  }

  .menu-tag--rare {
    background: rgba(106, 27, 154, 0.1);
    color: #6A1B9A;
  }

  .menu-tag--pasalubong {
    background: rgba(232, 101, 74, 0.1);
    color: var(--color-warm-coral);
  }

  .menu-tag--legendary {
    background: rgba(212, 168, 83, 0.15);
    color: #9A7B2E;
  }

  .menu-tag--nationaldish {
    background: rgba(191, 54, 12, 0.1);
    color: #BF360C;
  }

  /* ================================================================
     REGION SECTION
     ================================================================ */
  .menu-region {
    padding: var(--space-6) 0;
  }

  .menu-region-header {
    position: relative;
